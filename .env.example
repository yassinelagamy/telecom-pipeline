# Copy to .env and adjust. NEVER commit .env (gitignored). (D9)

# ── MinIO (data lake) ────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio
MINIO_BUCKET=telecom-lake
MINIO_ENDPOINT=http://minio:9000          # inside docker network
MINIO_ENDPOINT_HOST=http://localhost:9000 # from the host machine

# ── Postgres DWH (Dev B) ─────────────────────────────────────────
DWH_POSTGRES_USER=dwh_user
DWH_POSTGRES_PASSWORD=change-me-dwh
DWH_POSTGRES_DB=telecom_dwh
DWH_POSTGRES_HOST=postgres-dwh
DWH_POSTGRES_PORT=5432

# ── Airflow (Dev A) ──────────────────────────────────────────────
AIRFLOW_UID=50000
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=change-me-airflow
# Airflow metadata DB (separate from the DWH on purpose)
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=change-me-airflow-db
AIRFLOW_DB_NAME=airflow

# ── Metabase (Dev B) ─────────────────────────────────────────────
MB_DB_FILE=/metabase-data/metabase.db
MB_ADMIN_EMAIL=admin@telecom.local
MB_ADMIN_PASSWORD=TelecomLake-2026!Admin
MB_SITE_NAME=Telecom Analytics

# ── Generator defaults (Dev A) ───────────────────────────────────
GEN_EVENTS_PER_HOUR=10000
GEN_MALFORMED_RATE=0.02
GEN_NUM_SUBSCRIBERS=5000
GEN_NUM_TOWERS=200
